---
import Base from "../layouts/Base.astro";
import { todayUTC } from "../lib/calendar/dateUtils";
import { buildTodaySummaryTable1962 } from "../lib/calendar/1962/todaySummaryTable";
import { buildNovusOrdoTable } from "../lib/calendar/novusOrdoTable";
import { renderSections } from "../lib/render";
import { buildViewModel } from "../lib/viewModel";

const today = todayUTC();
const copyrightYear = today.getUTCFullYear();

const TABLE_YEARS_BEFORE = 10;
const TABLE_YEARS_AFTER = 10;
const minYear = copyrightYear - TABLE_YEARS_BEFORE;
const maxYear = copyrightYear + TABLE_YEARS_AFTER;
const novusOrdoTable = buildNovusOrdoTable(minYear, maxYear);
const todaySummaryTable1962 = await buildTodaySummaryTable1962(minYear, maxYear);
const minDate = `${minYear}-01-01`;
const maxDate = `${maxYear}-12-31`;

const vm = buildViewModel(today, novusOrdoTable, todaySummaryTable1962);

// Embedded for the client script to read without ever loading romcal (or
// making a live network call) itself — see novusOrdoLookup.ts and
// todaySummaryLookup.ts. Escape "<" so a stray "</script>"-like sequence in
// any celebration name can't break out of the tag.
const novusOrdoTableJson = JSON.stringify(novusOrdoTable).replace(/</g, "\\u003c");
const todaySummaryTable1962Json = JSON.stringify(todaySummaryTable1962).replace(/</g, "\\u003c");
---

<Base>
  <header class="site-header">
    <h1>Catholic Faith Today</h1>
    <p class="tagline">
      The Traditional 1962 calendar and the Novus Ordo calendar, side by side — <span id="date-label">{vm.dateLabel}</span>
    </p>
  </header>

  <div class="date-picker-bar">
    <label for="date-input">View a different date</label>
    <input type="date" id="date-input" value={vm.isoDate} min={minDate} max={maxDate} />
    <button id="today-button" type="button">Today</button>
  </div>

  <div id="sections" set:html={renderSections(vm)} />

  <footer class="site-footer">
    <p>CatholicFaith.Today &mdash; comparing the Extraordinary and Ordinary Forms of the Roman Rite.</p>
    <p>&copy; <span id="copyright-year">{copyrightYear}</span> Jeff Stempel</p>
  </footer>

  <script type="application/json" id="novus-ordo-table" is:inline set:html={novusOrdoTableJson} />
  <script type="application/json" id="today-summary-table-1962" is:inline set:html={todaySummaryTable1962Json} />

  <script>
    import { fromISODate, todayLocal, toISODate } from "../lib/calendar/dateUtils";
    import type { NovusOrdoTable } from "../lib/calendar/novusOrdoLookup";
    import type { TodaySummaryTable1962 } from "../lib/calendar/1962/todaySummaryLookup";
    import { renderSections } from "../lib/render";
    import { buildViewModel } from "../lib/viewModel";

    const tableEl = document.getElementById("novus-ordo-table")!;
    const novusOrdoTable: NovusOrdoTable = JSON.parse(tableEl.textContent ?? "{}");

    const todaySummaryTableEl = document.getElementById("today-summary-table-1962")!;
    const todaySummaryTable1962: TodaySummaryTable1962 = JSON.parse(todaySummaryTableEl.textContent ?? "{}");

    const sectionsEl = document.getElementById("sections")!;
    const dateLabelEl = document.getElementById("date-label")!;
    const copyrightYearEl = document.getElementById("copyright-year")!;
    const dateInput = document.getElementById("date-input") as HTMLInputElement;
    const todayButton = document.getElementById("today-button")!;

    // The URL's ?date= is the shareable permalink for a specific day. Social
    // previews stay generic (see Base.astro) — a query string can't change
    // what a crawler sees, since it's the same static file regardless — but
    // a human following the link should land on that actual date.
    function updateUrlForDate(iso: string, todayIso: string) {
      const url = new URL(window.location.href);
      if (iso === todayIso) {
        url.searchParams.delete("date");
      } else {
        url.searchParams.set("date", iso);
      }
      history.replaceState(null, "", url);
    }

    function renderFor(date: Date, todayIso: string) {
      const vm = buildViewModel(date, novusOrdoTable, todaySummaryTable1962);
      sectionsEl.innerHTML = renderSections(vm);
      dateLabelEl.textContent = vm.dateLabel;
      dateInput.value = vm.isoDate;
      updateUrlForDate(vm.isoDate, todayIso);
    }

    // The page is statically built ahead of time, so its initial content can
    // be stale by however long it's been since the last deploy — and UTC's
    // day boundary doesn't line up with the visitor's own midnight anyway.
    // Immediately recompute using the visitor's own local calendar date to
    // correct both on every load — unless a specific date was requested via
    // ?date=, in which case that's a shared permalink and should win instead
    // of silently jumping back to today.
    const browserToday = todayLocal();
    const todayIso = toISODate(browserToday);
    copyrightYearEl.textContent = String(browserToday.getUTCFullYear());

    const requestedDate = new URLSearchParams(window.location.search).get("date");
    const parsedRequestedDate = requestedDate ? fromISODate(requestedDate) : null;
    const initialDate = parsedRequestedDate && !Number.isNaN(parsedRequestedDate.getTime()) ? parsedRequestedDate : browserToday;

    renderFor(initialDate, todayIso);

    dateInput.addEventListener("change", () => {
      if (!dateInput.value) return;
      renderFor(fromISODate(dateInput.value), todayIso);
    });

    todayButton.addEventListener("click", () => {
      renderFor(browserToday, todayIso);
    });
  </script>
</Base>
