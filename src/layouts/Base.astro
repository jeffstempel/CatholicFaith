---
import "../styles/global.css";
import NavMenu from "../components/NavMenu.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Catholic Faith Today",
  description = "The Traditional 1962 and Novus Ordo Catholic calendars, side by side: Ember Days, Solemnities, Feast Days, and the Saint of the Day.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={new URL(Astro.url.pathname, "https://www.catholicfaith.today").toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <NavMenu currentPath={Astro.url.pathname} />
      <slot />
    </div>
  </body>
</html>
