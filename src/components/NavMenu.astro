---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
];

// Astro.url.pathname may or may not carry a trailing slash depending on how
// the page is served; normalize both sides before comparing.
const normalize = (path: string) => (path.length > 1 ? path.replace(/\/$/, "") : path);
const normalizedCurrent = normalize(currentPath);
---

<nav class="site-nav">
  <details class="nav-dropdown">
    <summary>Menu</summary>
    <ul>
      {links.map((link) => (
        <li>
          <a href={link.href} aria-current={normalizedCurrent === normalize(link.href) ? "page" : undefined}>{link.label}</a>
        </li>
      ))}
    </ul>
  </details>
</nav>
